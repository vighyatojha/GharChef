<?xml version="1.0" encoding="utf-8"?>
<!-- Brown/red square with inner red circle — standard non-veg symbol -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer red border square -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B71C1C" />
            <corners android:radius="3dp" />
            <size android:width="18dp" android:height="18dp" />
        </shape>
    </item>

    <!-- Inner white padding -->
    <item
        android:top="2dp"
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Inner red circle -->
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="#B71C1C" />
        </shape>
    </item>

</layer-list>