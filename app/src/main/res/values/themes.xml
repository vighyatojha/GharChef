<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.GharChef" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_light</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:statusBarColor">@color/bg_cream</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash screen - no action bar, full screen feel -->
    <style name="Theme.GharChef.Splash" parent="Theme.GharChef">
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/bg_light</item>
    </style>
</resources>