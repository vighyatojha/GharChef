<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardProduct"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_alignParentTop="true"
            android:contentDescription="Dish image"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/tvProductCategory"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_alignTop="@id/ivProductImage"
            android:layout_alignStart="@id/ivProductImage"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_category_badge"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="🇮🇳 North Indian" />

        <RelativeLayout
            android:id="@+id/rlTimeBadge"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_below="@id/tvProductCategory"
            android:layout_alignStart="@id/tvProductCategory"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_time_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <ImageView
                android:id="@+id/ivTimeClock"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:contentDescription="Cook time"
                android:src="@drawable/ic_clock_white" />

            <TextView
                android:id="@+id/tvTimeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="4dp"
                android:layout_toEndOf="@id/ivTimeClock"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="30 min" />
        </RelativeLayout>

        <ImageView
            android:id="@+id/ivVegIndicator"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignTop="@id/ivProductImage"
            android:layout_alignEnd="@id/ivProductImage"
            android:layout_marginTop="54dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Veg or Non-Veg"
            android:src="@drawable/ic_veg_indicator" />

        <ImageView
            android:id="@+id/ivHeart"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignTop="@id/ivProductImage"
            android:layout_alignEnd="@id/ivProductImage"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_heart_button"
            android:contentDescription="Add to favourites"
            android:padding="8dp"
            android:src="@drawable/ic_heart_outline"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/tvProductTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/ivProductImage"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/tvProductPrice"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Paneer Butter Masala" />

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ivProductImage"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/green_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="₹249" />

        <LinearLayout
            android:id="@+id/llRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvProductTitle"
            android:layout_alignParentStart="true"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvRatingStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFA000"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="★ 4.7" />

            <TextView
                android:id="@+id/tvRatingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="(120+ reviews)" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/llRating"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="14dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Rich, creamy paneer cooked in tomato-butter gravy. Best served with naan." />

        <Button
            android:id="@+id/btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_below="@id/tvProductDescription"
            android:layout_marginStart="14dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_button_green_outline"
            android:drawableStart="@drawable/ic_cart_green"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:stateListAnimator="@null"
            android:text="@string/add_to_cart"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>