<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EA">

    <RelativeLayout android:id="@+id/header"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#F5F0EA" android:paddingStart="16dp" android:paddingEnd="16dp">
        <ImageView android:id="@+id/ivBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back" android:background="@drawable/bg_back_button"
            android:padding="8dp" android:contentDescription="Back" />
        <TextView android:id="@+id/tvUserOrdersTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="User Orders" android:textColor="#1A1A2E"
            android:textSize="18sp" android:textStyle="bold" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvUserOrders"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:clipToPadding="false" />
</RelativeLayout>