<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF6EC"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero Header Section ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="260dp">

            <!-- Background food image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Food"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_login_header" />

            <!-- Gradient overlay for readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_gradient_overlay" />

            <!-- Branding inside hero -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GharChef"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:letterSpacing="0.03" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Home-cooked, heart-warmed"
                    android:textColor="#FFE8C4"
                    android:textSize="13sp"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </FrameLayout>

        <!-- ── Main Form Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_form_card_top_rounded"
            android:layout_marginTop="-20dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- Welcome heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back 👋"
                android:textColor="#1A1A2E"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Sign in to continue ordering delicious meals"
                android:textColor="#9A8F85"
                android:textSize="14sp" />

            <!-- ── Email Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Email Address"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="✉"
                    android:textColor="#C0956A"
                    android:textSize="16sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="your@email.com"
                    android:textColorHint="#C5BAB2"
                    android:inputType="textEmailAddress"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Password Field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Password"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="🔒"
                    android:textColor="#C0956A"
                    android:textSize="14sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="Enter your password"
                    android:textColorHint="#C5BAB2"
                    android:inputType="textPassword"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/ivTogglePassword"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="Toggle password"
                    android:padding="6dp"
                    app:tint="#C0956A" />
            </LinearLayout>

            <!-- Forgot password -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:text="Forgot Password?"
                android:textColor="#E8871A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- ── Login Button ── -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_primary_v2"
                android:stateListAnimator="@null"
                android:text="Login"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <!-- ── Divider ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E0D8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="or continue with"
                    android:textColor="#B5A99F"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E0D8" />
            </LinearLayout>

            <!-- ── Social Buttons ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_social_button_v2"
                    android:stateListAnimator="@null"
                    android:text="Google"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="8dp" />

                <Button
                    android:id="@+id/btnApple"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_social_button_v2"
                    android:stateListAnimator="@null"
                    android:text="Apple"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_apple"
                    android:drawablePadding="8dp" />
            </LinearLayout>

            <!-- ── Sign Up Link ── -->
            <TextView
                android:id="@+id/tvSignup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Don't have an account? "
                android:textColor="#9A8F85"
                android:textSize="14sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>