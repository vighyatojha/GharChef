<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Image Preview -->
        <ImageView
            android:id="@+id/ivItemImagePreview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_login_header"
            android:contentDescription="Dish image preview" />

        <!-- Image URL input -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Image URL" android:textColor="#888888"
            android:textSize="12sp" android:textStyle="bold" />
        <EditText android:id="@+id/etItemImageUrl"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input_field"
            android:hint="https://..." android:textColorHint="#BBBBBB"
            android:inputType="textUri"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:textColor="#1A1A2E" android:textSize="13sp" />

        <!-- Dish Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Dish Name" android:textColor="#1A1A2E"
            android:textSize="14sp" android:textStyle="bold" />
        <EditText android:id="@+id/etItemName"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:hint="e.g. Paneer Butter Masala" android:textColorHint="#BBBBBB"
            android:inputType="textCapWords"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:textColor="#1A1A2E" android:textSize="14sp" />

        <!-- Description -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Description" android:textColor="#1A1A2E"
            android:textSize="14sp" android:textStyle="bold" />
        <EditText android:id="@+id/etItemDesc"
            android:layout_width="match_parent" android:layout_height="80dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:hint="Rich description of the dish..."
            android:textColorHint="#BBBBBB"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="12dp"
            android:textColor="#1A1A2E" android:textSize="14sp"
            android:gravity="top" />

        <!-- Price + Category -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal" android:weightSum="2">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Price (₹)" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <EditText android:id="@+id/etItemPrice"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="0.00" android:textColorHint="#BBBBBB"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:textColor="#1A1A2E" android:textSize="14sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Category" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <Spinner android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="10dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Prep Time + Rating -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal" android:weightSum="2">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prep Time (min)" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <EditText android:id="@+id/etItemPrepTime"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="30 mins" android:textColorHint="#BBBBBB"
                    android:inputType="text"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:textColor="#1A1A2E" android:textSize="14sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Avg. Rating" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <EditText android:id="@+id/etItemRating"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="4.5" android:textColorHint="#BBBBBB"
                    android:inputType="numberDecimal"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:textColor="#1A1A2E" android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Available toggle -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input_field"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Available" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Show on menu for users" android:textColor="#AAAAAA" android:textSize="12sp" />
            </LinearLayout>
            <Switch android:id="@+id/switchAvailable"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#E8871A" android:trackTint="#FFE0B2" />
        </LinearLayout>

        <!-- Popular toggle -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_field"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Popular Choice" android:textColor="#1A1A2E"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Display in 'Most Loved' section" android:textColor="#AAAAAA" android:textSize="12sp" />
            </LinearLayout>
            <Switch android:id="@+id/switchPopular"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#E8871A" android:trackTint="#FFE0B2" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="8dp" />
    </LinearLayout>
</ScrollView>