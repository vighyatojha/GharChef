<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EA">

    <!-- BOTTOM NAV -->
    <LinearLayout android:id="@+id/adminBottomNav"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF" android:elevation="8dp"
        android:orientation="horizontal" android:weightSum="5">
        <LinearLayout android:id="@+id/navAdminDashboard" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_grid" app:tint="#AAAAAA" android:contentDescription="Dash" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dashboard" android:textColor="#AAAAAA" android:textSize="8sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminUsers" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_users" app:tint="#E8871A" android:contentDescription="Users" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Users" android:textColor="#E8871A" android:textSize="9sp" android:textStyle="bold" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminOrders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_orders" app:tint="#AAAAAA" android:contentDescription="Orders" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orders" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminItems" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_menu" app:tint="#AAAAAA" android:contentDescription="Menu" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chefs" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_settings" app:tint="#AAAAAA" android:contentDescription="Settings" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- HEADER -->
    <RelativeLayout android:id="@+id/header"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#F5F0EA" android:paddingStart="16dp" android:paddingEnd="16dp">
        <ImageView android:id="@+id/ivBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back" android:background="@drawable/bg_back_button"
            android:padding="8dp" android:contentDescription="Back" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Admin Users" android:textColor="#1A1A2E"
            android:textSize="18sp" android:textStyle="bold" />
        <ImageView android:id="@+id/ivMore"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_alignParentEnd="true" android:layout_centerVertical="true"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="More" />
    </RelativeLayout>

    <!-- SEARCH -->
    <RelativeLayout android:id="@+id/searchLayout"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_below="@id/header"
        android:background="#FFFFFF"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:elevation="1dp">
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_search" app:tint="#E8871A" android:contentDescription="Search" />
        <EditText android:id="@+id/etSearchUsers"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:layout_marginStart="36dp"
            android:background="@null"
            android:hint="Search users by name or email"
            android:textColorHint="#BBBBBB"
            android:inputType="text" android:textColor="#1A1A2E" android:textSize="14sp" />
    </RelativeLayout>

    <!-- TABS -->
    <LinearLayout android:id="@+id/tabsLayout"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_below="@id/searchLayout"
        android:background="#FFFFFF"
        android:orientation="horizontal" android:paddingStart="16dp">
        <TextView android:id="@+id/tabAllUsers"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:gravity="center" android:text="All Users"
            android:textColor="#E8871A" android:textSize="14sp" android:textStyle="bold"
            android:layout_marginEnd="24dp"
            android:background="@drawable/tab_indicator_bottom" />
        <TextView android:id="@+id/tabActive"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:gravity="center" android:text="Active"
            android:textColor="#AAAAAA" android:textSize="14sp"
            android:layout_marginEnd="24dp" />
        <TextView android:id="@+id/tabSuspended"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:gravity="center" android:text="Suspended"
            android:textColor="#AAAAAA" android:textSize="14sp" />
    </LinearLayout>

    <!-- PROGRESS -->
    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="match_parent" android:layout_height="3dp"
        android:layout_below="@id/tabsLayout"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true" android:indeterminateTint="#E8871A"
        android:visibility="gone" />

    <!-- EMPTY -->
    <TextView android:id="@+id/tvEmpty"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_below="@id/tabsLayout" android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:text="No users found" android:textColor="#AAAAAA" android:textSize="15sp"
        android:visibility="gone" />

    <!-- RECYCLER -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvUsers"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/tabsLayout"
        android:layout_above="@id/adminBottomNav"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddUser"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/adminBottomNav"
        android:layout_marginEnd="16dp" android:layout_marginBottom="16dp"
        android:src="@drawable/ic_person_add"
        app:backgroundTint="#E8871A" app:tint="#FFFFFF"
        android:contentDescription="Add user" />

</RelativeLayout>