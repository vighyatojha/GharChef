<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Status icon circle -->
        <FrameLayout android:id="@+id/flStatusIcon"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="@drawable/bg_stat_icon_orange">
            <ImageView android:id="@+id/ivStatusIcon"
                android:layout_width="22dp" android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:contentDescription="Order status" />
        </FrameLayout>

        <!-- Details -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView android:id="@+id/tvRecentOrderId"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Order #0000 – Item"
                android:textColor="#1A1A2E" android:textSize="14sp" android:textStyle="bold" />

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="3dp" android:gravity="center_vertical">
                <View android:id="@+id/dotStatus"
                    android:layout_width="7dp" android:layout_height="7dp"
                    android:background="@drawable/bg_dot_orange" />
                <TextView android:id="@+id/tvRecentOrderStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="Preparing • 2 mins ago"
                    android:textColor="#AAAAAA" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Amount -->
        <TextView android:id="@+id/tvRecentOrderAmount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="₹0" android:textColor="#1A1A2E"
            android:textSize="15sp" android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>