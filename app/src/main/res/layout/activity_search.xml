<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F5F0EA">

    <!-- SEARCH HEADER -->
    <RelativeLayout android:id="@+id/searchHeader"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#FFFFFF" android:paddingStart="8dp" android:paddingEnd="16dp"
        android:elevation="4dp">
        <ImageView android:id="@+id/ivBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back" android:background="@drawable/bg_back_button"
            android:padding="10dp" android:contentDescription="Back"/>
        <RelativeLayout android:layout_width="match_parent" android:layout_height="44dp"
            android:layout_toEndOf="@id/ivBack" android:layout_centerVertical="true"
            android:layout_marginStart="8dp" android:background="@drawable/bg_input_field">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:layout_centerVertical="true" android:layout_marginStart="14dp"
                android:src="@drawable/ic_search" app:tint="#E8871A" android:contentDescription="Search"/>
            <EditText android:id="@+id/etSearchQuery"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:layout_marginStart="40dp" android:background="@null"
                android:hint="Search dishes, cuisines..." android:textColorHint="#BBBBBB"
                android:inputType="text" android:textColor="#1A1A2E" android:textSize="14sp"
                android:imeOptions="actionSearch"/>
        </RelativeLayout>
    </RelativeLayout>

    <!-- STANDARD USER BOTTOM NAV — 5 tabs -->
    <LinearLayout android:id="@+id/bottomNav"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF" android:elevation="12dp"
        android:orientation="horizontal" android:weightSum="5">
        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_home" app:tint="#AAAAAA" android:contentDescription="Home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navSearch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_search" app:tint="#E8871A" android:contentDescription="Search"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Search" android:textColor="#E8871A" android:textSize="9sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navOrders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_orders" app:tint="#AAAAAA" android:contentDescription="Orders"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orders" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navCart" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_cart" app:tint="#AAAAAA" android:contentDescription="Cart"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cart" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_profile" app:tint="#AAAAAA" android:contentDescription="Profile"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="match_parent" android:layout_height="3dp"
        android:layout_below="@id/searchHeader"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true" android:indeterminateTint="#E8871A" android:visibility="gone"/>

    <!-- EMPTY STATE -->
    <LinearLayout android:id="@+id/tvSearchEmpty"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_below="@id/searchHeader" android:layout_above="@id/bottomNav"
        android:layout_centerHorizontal="true" android:layout_marginTop="80dp"
        android:gravity="center" android:orientation="vertical" android:visibility="gone">
        <ImageView android:layout_width="60dp" android:layout_height="60dp"
            android:src="@drawable/ic_search" app:tint="#DDDDDD" android:contentDescription="Empty"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:text="No dishes found"
            android:textColor="#AAAAAA" android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:text="Try a different search term"
            android:textColor="#BBBBBB" android:textSize="13sp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvSearchResults"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/searchHeader" android:layout_above="@id/bottomNav"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="8dp" android:clipToPadding="false"/>
</RelativeLayout>