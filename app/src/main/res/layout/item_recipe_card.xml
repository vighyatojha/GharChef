<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvRecipeKitName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dish Name"
            android:textColor="#1A1A2E"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvRecipeServes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Serves 2"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvRecipeDifficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Easy"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvRecipePrepTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱ 20 mins"
                android:textSize="11sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- INGREDIENTS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingredients"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:id="@+id/ingredientsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- STEPS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Steps"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="10dp" />

        <LinearLayout
            android:id="@+id/stepsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- COOKWARE -->
        <TextView
            android:id="@+id/tvCookware"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍳 Pan"
            android:textSize="12sp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tvCookwareSubs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alternative cookware"
            android:textSize="11sp"
            android:textColor="#888888" />

    </LinearLayout>
</androidx.cardview.widget.CardView>