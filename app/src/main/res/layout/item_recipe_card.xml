<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER BAND -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#FFF8F0"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvRecipeKitName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Dish Name"
                    android:textColor="#1A1A2E" android:textSize="16sp" android:textStyle="bold"/>

                <!-- Badges: serves, difficulty, time -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">

                    <TextView android:id="@+id/tvRecipeServes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👥 2 Serves"
                        android:textSize="11sp" android:textColor="#E8871A" android:textStyle="bold"
                        android:background="#FFE8CC"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/tvRecipeDifficulty"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡ Easy"
                        android:textSize="11sp" android:textColor="#2E7D32" android:textStyle="bold"
                        android:background="#E8F5E9"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/tvRecipePrepTime"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⏱ 20 mins"
                        android:textSize="11sp" android:textColor="#1565C0" android:textStyle="bold"
                        android:background="#E3F2FD"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- INGREDIENTS SECTION -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <View android:layout_width="4dp" android:layout_height="18dp"
                    android:background="#E8871A" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="What's in the Kit"
                    android:textColor="#1A1A2E" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/ingredientsContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FAFAFA"
                android:padding="12dp"/>

            <!-- COOKWARE -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="14dp" android:layout_marginBottom="6dp">
                <View android:layout_width="4dp" android:layout_height="18dp"
                    android:background="#E8871A" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cookware Needed"
                    android:textColor="#1A1A2E" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <TextView android:id="@+id/tvCookware"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="🍳 Pan"
                android:textColor="#444444" android:textSize="13sp"
                android:background="#FFF8F0"
                android:padding="12dp"/>

            <TextView android:id="@+id/tvCookwareSubs"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Don't have it? No worries!"
                android:textColor="#888888" android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:paddingStart="12dp"/>
        </LinearLayout>

        <!-- DIVIDER -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F0F0F0" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

        <!-- RECIPE STEPS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <View android:layout_width="4dp" android:layout_height="18dp"
                    android:background="#E8871A" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Step-by-Step Recipe"
                    android:textColor="#1A1A2E" android:textSize="15sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/stepsContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>