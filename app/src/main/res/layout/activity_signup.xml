<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF6EC"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Decorative Top Bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_signup_header_band"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:orientation="vertical">

            <!-- Back + Title row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back"
                    android:background="@drawable/bg_back_button_light"
                    android:padding="8dp"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="GharChef"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="serif" />
            </RelativeLayout>

            <!-- Heading under bar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Join thousands enjoying home-cooked meals"
                android:textColor="#FFE8C4"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ── Form Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_form_card_top_rounded"
            android:layout_marginTop="-18dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- ── Step indicator ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="28dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_step_active" />
                <View
                    android:layout_width="8dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_step_inactive" />
                <View
                    android:layout_width="8dp"
                    android:layout_height="4dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_step_inactive" />
            </LinearLayout>

            <!-- ── Section label: Personal Info ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERSONAL INFO"
                android:textColor="#C0956A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="#E8871A" />

            <!-- ── Username ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="@"
                    android:textColor="#C0956A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="e.g. anjali_sharma"
                    android:textColorHint="#C5BAB2"
                    android:inputType="text"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Full Name ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Full Name"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="👤"
                    android:textColor="#C0956A"
                    android:textSize="14sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="Your full name"
                    android:textColorHint="#C5BAB2"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Thin divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="#F0E8DC" />

            <!-- ── Section label: Contact ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT DETAILS"
                android:textColor="#C0956A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <View
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="#E8871A" />

            <!-- ── Mobile ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Country prefix chip -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_prefix_chip"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇮🇳 +91"
                        android:textColor="#4A3728"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="#E0D4C8" />

                <EditText
                    android:id="@+id/etMobile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="10-digit number"
                    android:textColorHint="#C5BAB2"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Email ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Email Address"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="✉"
                    android:textColor="#C0956A"
                    android:textSize="16sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etSignupEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="your@email.com"
                    android:textColorHint="#C5BAB2"
                    android:inputType="textEmailAddress"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ── Password ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Password"
                android:textColor="#4A3728"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="🔒"
                    android:textColor="#C0956A"
                    android:textSize="14sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etSignupPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="Min 6 characters"
                    android:textColorHint="#C5BAB2"
                    android:inputType="textPassword"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Password strength hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Use letters, numbers &amp; symbols for a strong password"
                android:textColor="#B5A99F"
                android:textSize="11sp" />

            <!-- ── Create Account Button ── -->
            <Button
                android:id="@+id/btnSignup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_primary_v2"
                android:stateListAnimator="@null"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <!-- Terms note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="By creating an account, you agree to our Terms &amp; Privacy Policy"
                android:textColor="#B5A99F"
                android:textSize="11sp" />

            <!-- ── Login Link ── -->
            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Already have an account? Login"
                android:textColor="#E8871A"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>