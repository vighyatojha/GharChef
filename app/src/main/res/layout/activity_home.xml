<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EA">

    <!-- BOTTOM NAV — 5 TABS (CRASH FIX: navProfile was missing) -->
    <LinearLayout android:id="@+id/bottomNavHome"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF" android:elevation="8dp"
        android:orientation="horizontal" android:weightSum="5">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" app:tint="#E8871A" android:contentDescription="Home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="#E8871A"
                android:textSize="10sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navSearch"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_search" app:tint="#AAAAAA" android:contentDescription="Search"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Search" android:textColor="#AAAAAA"
                android:textSize="10sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navOrders"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_orders" app:tint="#AAAAAA" android:contentDescription="Orders"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Orders" android:textColor="#AAAAAA"
                android:textSize="10sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navCart"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_cart" app:tint="#AAAAAA" android:contentDescription="Cart"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cart" android:textColor="#AAAAAA"
                android:textSize="10sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- CRASH FIX: this tab was missing entirely -->
        <LinearLayout android:id="@+id/navProfile"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_profile" app:tint="#AAAAAA" android:contentDescription="Profile"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textColor="#AAAAAA"
                android:textSize="10sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_above="@id/bottomNavHome" android:scrollbars="none">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="64dp"
                android:background="#F5F0EA"
                android:paddingStart="16dp" android:paddingEnd="16dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_centerVertical="true" android:orientation="vertical">
                    <TextView android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hello! 👋"
                        android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="What would you like to cook today?"
                        android:textColor="#888888" android:textSize="12sp"/>
                </LinearLayout>
                <ImageView android:id="@+id/ivCart"
                    android:layout_width="42dp" android:layout_height="42dp"
                    android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                    android:background="@drawable/bg_icon_btn"
                    android:src="@drawable/ic_cart" android:padding="10dp"
                    app:tint="#E8871A" android:contentDescription="Cart"/>
            </RelativeLayout>

            <!-- SEARCH BAR -->
            <RelativeLayout android:id="@+id/searchBar"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="#FFFFFF"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:elevation="3dp">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_search" app:tint="#E8871A" android:contentDescription="Search"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginStart="36dp" android:layout_centerVertical="true"
                    android:text="Search meal kits, cuisines..."
                    android:textColor="#BBBBBB" android:textSize="14sp"/>
            </RelativeLayout>

            <!-- HERO BANNER -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="160dp"
                android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp" app:cardElevation="6dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_banner">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical" android:layout_marginStart="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cook It Yourself 🍳"
                            android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Pre-prepped kits. Your kitchen. Real food."
                            android:textColor="#E0FFFFFF" android:textSize="13sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="#33FFFFFF"
                            android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:paddingTop="5dp" android:paddingBottom="5dp"
                            android:text="No chopping · No measuring"
                            android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- CATEGORY CHIPS — all 8 cuisine types -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp" android:paddingEnd="16dp">

                    <TextView android:id="@+id/chipAll"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🍽 All Kits"
                        android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold"/>

                    <TextView android:id="@+id/chipNorthIndian"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🫓 North Indian"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipSouthIndian"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🥞 South Indian"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipWestIndian"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🧆 West Indian"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipEastIndian"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🍛 East Indian"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipChinese"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🍜 Chinese"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipStreetFood"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:layout_marginEnd="10dp"
                        android:text="🥙 Street Food"
                        android:textColor="#888888" android:textSize="13sp"/>

                    <TextView android:id="@+id/chipDesserts"
                        android:layout_width="wrap_content" android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="18dp" android:paddingEnd="18dp"
                        android:text="🍮 Desserts"
                        android:textColor="#888888" android:textSize="13sp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal" android:visibility="gone"/>

            <!-- TOP KITS SECTION -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Top Kits 🔥"
                    android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="See all"
                    android:textColor="#E8871A" android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPopularItems"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingStart="16dp" android:clipToPadding="false"
                android:layout_marginBottom="20dp"
                android:nestedScrollingEnabled="false"/>

            <!-- ALL KITS SECTION -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="10dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="All Meal Kits"
                    android:textColor="#1A1A2E" android:textSize="18sp" android:textStyle="bold"/>
            </LinearLayout>

            <TextView android:id="@+id/tvNoItems"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:text="No kits available" android:textColor="#AAAAAA" android:textSize="14sp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllItems"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingStart="12dp" android:paddingEnd="12dp"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"/>

            <View android:layout_width="match_parent" android:layout_height="16dp"/>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>