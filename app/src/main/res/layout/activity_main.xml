<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF6EE">

    <!-- Centered content block -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Orange circle background with pot icon -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_splash_circle">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cooking_pot"
                android:contentDescription="GharChef Logo" />
        </FrameLayout>

        <!-- GharChef title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="GharChef"
            android:textColor="#1A1A2E"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="TASTE OF HOME"
            android:textColor="#E8871A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />
    </LinearLayout>

</RelativeLayout>