<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EA">

    <!-- BOTTOM NAV -->
    <LinearLayout android:id="@+id/adminBottomNav"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF" android:elevation="8dp"
        android:orientation="horizontal" android:weightSum="5">
        <LinearLayout android:id="@+id/navAdminDashboard" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_grid" app:tint="#AAAAAA" android:contentDescription="Dash" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DASH" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminOrders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_orders" app:tint="#E8871A" android:contentDescription="Orders" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ORDERS" android:textColor="#E8871A" android:textSize="9sp" android:textStyle="bold" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminItems" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_menu" app:tint="#AAAAAA" android:contentDescription="Menu" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MENU" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminUsers" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_users" app:tint="#AAAAAA" android:contentDescription="Users" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USERS" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
        <LinearLayout android:id="@+id/navAdminProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_admin_settings" app:tint="#AAAAAA" android:contentDescription="Config" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONFIG" android:textColor="#AAAAAA" android:textSize="9sp" android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- HEADER -->
    <RelativeLayout android:id="@+id/header"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:background="#F5F0EA" android:paddingStart="16dp" android:paddingEnd="16dp">
        <ImageView android:id="@+id/ivBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back" android:background="@drawable/bg_back_button"
            android:padding="8dp" android:contentDescription="Back" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="All Orders" android:textColor="#1A1A2E"
            android:textSize="18sp" android:textStyle="bold" />
    </RelativeLayout>

    <!-- STATUS TABS HORIZONTAL SCROLL -->
    <HorizontalScrollView android:id="@+id/tabScroll"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_below="@id/header"
        android:background="#FFFFFF"
        android:scrollbars="none">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">
            <TextView android:id="@+id/tabAllOrders" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:text="All"
                android:textColor="#E8871A" android:textSize="13sp" android:textStyle="bold"
                android:layout_marginEnd="20dp" />
            <TextView android:id="@+id/tabPending" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:text="Confirmed"
                android:textColor="#AAAAAA" android:textSize="13sp"
                android:layout_marginEnd="20dp" />
            <TextView android:id="@+id/tabPreparing" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:text="Preparing"
                android:textColor="#AAAAAA" android:textSize="13sp"
                android:layout_marginEnd="20dp" />
            <TextView android:id="@+id/tabDelivery" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:text="Out for Delivery"
                android:textColor="#AAAAAA" android:textSize="13sp"
                android:layout_marginEnd="20dp" />
            <TextView android:id="@+id/tabDelivered" android:layout_width="wrap_content" android:layout_height="match_parent"
                android:gravity="center" android:text="Delivered"
                android:textColor="#AAAAAA" android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- PROGRESS -->
    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="match_parent" android:layout_height="3dp"
        android:layout_below="@id/tabScroll"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true" android:indeterminateTint="#E8871A"
        android:visibility="gone" />

    <!-- EMPTY -->
    <TextView android:id="@+id/tvEmpty"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_below="@id/tabScroll" android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:text="No orders found" android:textColor="#AAAAAA" android:textSize="15sp"
        android:visibility="gone" />

    <!-- RECYCLER -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvAdminOrders"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/tabScroll"
        android:layout_above="@id/adminBottomNav"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:clipToPadding="false" />
</RelativeLayout>